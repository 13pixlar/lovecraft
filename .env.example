# Vite (browser). Copy to .env.local and fill from Supabase Dashboard → Settings → API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Canonical public URL (no trailing slash). Used for sitemap, Open Graph, canonical links, and JSON-LD.
# Set in production builds (e.g. .env.production). For local dev it falls back to the current origin.
# VITE_SITE_URL=https://www.example.com

# Loader script scripts/load_lovecraft_catalog.py (never commit service role to git)
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
